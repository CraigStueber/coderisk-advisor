# CodeRisk Advisor — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith Tracing
LANGCHAIN_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="coderisk-advisor"

# CORS — comma separated, no spaces
ALLOWED_ORIGINS=http://localhost:5173,https://coderisk.craigstueber.com

# Session
SESSION_TTL_SECONDS=3600

# Redis (optional — leave blank for local dev)
# REDIS_URL=redis://localhost:6379